datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(cuid())
  spotifyId    String   @unique
  accessToken  String
  refreshToken String
  expiresAt    Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
